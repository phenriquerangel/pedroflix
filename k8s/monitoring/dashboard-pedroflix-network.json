  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83d\udce1  Por Servi\u00e7o (pedroflix)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Upload por servi\u00e7o \u2b06 (bytes enviados)",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "rate(pod_network_transmit_bytes_total{namespace=\"pedroflix\"}[2m])",
          "legendFormat": "{{ pod }}"
        }
      ]
    },
    {
